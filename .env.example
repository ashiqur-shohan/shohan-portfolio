# Supabase — project URL + keys (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service-role key: SERVER-ONLY. Never expose to the browser. (CLAUDE.md rule #2)
SUPABASE_SERVICE_ROLE_KEY=

# Single allowlisted admin email used to gate /admin
ADMIN_EMAIL=

# Resend — contact form delivery (Phase 1)
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# Public site origin (used for metadataBase, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
