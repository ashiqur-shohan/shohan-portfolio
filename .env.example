# Supabase — project URL + keys (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key (formerly "service_role key"): SERVER-ONLY. Never expose to the
# browser. Acts as the service_role Postgres role. (CLAUDE.md rule #2)
SUPABASE_SECRET_KEY=

# Single allowlisted admin email used to gate /admin
ADMIN_EMAIL=

# Resend — contact form delivery (Phase 1)
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# Public site origin (used for metadataBase, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
